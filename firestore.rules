rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
         request.auth.token.email == "teletechnologyci@gmail.com" ||
         request.auth.token.email == "ourega.goble@CANTIC-THINK-IA.work");
    }

    match /admins {
      allow list: if isAuthenticated();
      match /{docId} {
        allow read: if isAuthenticated() && (request.auth.uid == docId || isAdmin());
        allow write: if isAdmin();
      }
    }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'categoryId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.authorId is string && data.authorId.size() > 0 &&
             data.categoryId is string && data.categoryId.size() > 0 &&
             data.createdAt is string;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['content', 'authorId', 'postId', 'createdAt']) &&
             data.content is string && data.content.size() > 0 && data.content.size() < 2000 &&
             data.authorId is string && data.authorId.size() > 0 &&
             data.postId is string && data.postId.size() > 0 &&
             data.createdAt is string;
    }

    match /forum_categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /forum_posts/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
    }
    match /forum_comments/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
