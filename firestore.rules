rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isAuthenticated() { return request.auth != null; }
    function isAdmin() { 
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
         request.auth.token.email in ["teletechnologyci@gmail.com", "ourega.goble@CANTIC-THINK-IA.work"]); 
    }
    function isGrandColibri() {
      return isAuthenticated() && exists(/databases/$(database)/documents/grand_colibris/$(request.auth.uid));
    }
    function isManager() { return isAdmin() || isGrandColibri(); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'categoryId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.categoryId is string && data.categoryId.size() > 0 &&
             data.createdAt is string; // Should ideally check server time
    }
    function isValidVictory(data) {
      return data.keys().hasAll(['userId', 'userName', 'title', 'description', 'category', 'createdAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 2000 &&
             data.category in ['IA', 'Technique', 'Autre'] &&
             data.createdAt is string;
    }

    // --- Rules ---
    match /{document=**} { allow read, write: if false; }

    match /_connection_test_/{docId} {
      allow read: if true;
    }

    match /grand_colibris/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /admins/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
    match /forum_categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /forum_posts/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
      allow delete: if isAuthenticated() && ((request.auth.uid == resource.data.authorId && resource.data.status == 'draft') || isAdmin());
    }
    match /subscribers/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /contacts/{docId} {
      allow read: if isAdmin();
      allow create: if true;
    }
    match /auditLogs/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /cases/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /appointments/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin();
    }
    match /quotes/{docId} {
      allow read: if true;
      allow create: if true;
    }
    match /campaigns/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /realizations/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /posts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /comments/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }
    match /formations/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /registrations/{docId} {
      allow read: if isAdmin();
      allow create: if true;
    }
    match /resources/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /transactions/{docId} {
      allow read: if isAuthenticated() && (resource.data.userEmail == request.auth.token.email || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }
    match /victories/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidVictory(request.resource.data);
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isManager());
      
      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    match /user_stats/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isManager());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid == userId && 
                       request.resource.data.userId == resource.data.userId &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPoints', 'badges', 'bio', 'title']);
    }
    match /user_consents/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }
    match /user_profiles/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }
    match /user_projects/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isManager());
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    match /activities/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isManager());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    match /friends/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.friendId == request.auth.uid || isManager());
      allow create, delete: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || request.resource.data.friendId == request.auth.uid);
    }
  }
}
